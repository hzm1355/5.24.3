<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== 机器人底盘 ==================== -->
  <xacro:macro name="robot_base" params="prefix">

    <!-- ==================== 底盘主体 ==================== -->
    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <geometry>
          <box size="0.6 0.5 0.3"/>
        </geometry>
        <material name="base_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <geometry>
          <box size="0.6 0.5 0.3"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.15" rpy="0 0 0"/>
        <mass value="25.0"/>
        <inertia ixx="0.3125" iyy="0.4125" izz="0.6875" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- ==================== 左轮 ==================== -->
    <link name="${prefix}left_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.1" length="0.05"/>
        </geometry>
        <material name="wheel_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.1" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.001525" iyy="0.001525" izz="0.005" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}left_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}left_wheel"/>
      <origin xyz="0.2 0.275 -0.05" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- ==================== 右轮 ==================== -->
    <link name="${prefix}right_wheel">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.1" length="0.05"/>
        </geometry>
        <material name="wheel_color"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.1" length="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.001525" iyy="0.001525" izz="0.005" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}right_wheel_joint" type="continuous">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}right_wheel"/>
      <origin xyz="0.2 -0.275 -0.05" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- ==================== 前后万向轮 ==================== -->
    <link name="${prefix}front_caster">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
        <material name="caster_color"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.00025" iyy="0.00025" izz="0.00025" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}front_caster_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}front_caster"/>
      <origin xyz="-0.2 0 -0.1" rpy="0 0 0"/>
    </joint>

    <link name="${prefix}back_caster">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
        <material name="caster_color"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="0.05"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.00025" iyy="0.00025" izz="0.00025" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}back_caster_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}back_caster"/>
      <origin xyz="-0.2 0 -0.1" rpy="0 0 0"/>
    </joint>

    <!-- ==================== Gazebo 差速驱动插件 ==================== -->
    <gazebo>
      <plugin name="gazebo_ros_diff_drive" filename="libgazebo_ros_diff_drive.so">
        <ros>
          <namespace>/robot</namespace>
        </ros>
        <update_rate>50</update_rate>
        <left_joint>${prefix}left_wheel_joint</left_joint>
        <right_joint>${prefix}right_wheel_joint</right_joint>
        <wheel_separation>0.55</wheel_separation>
        <wheel_diameter>0.2</wheel_diameter>
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>1.0</max_wheel_acceleration>
        <command_topic>cmd_vel</command_topic>
        <publish_wheel_tf>true</publish_wheel_tf>
        <publish_tf>true</publish_tf>
        <odometry_topic>odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>${prefix}base_link</robot_base_frame>
      </plugin>
    </gazebo>

  </xacro:macro>

</robot>
